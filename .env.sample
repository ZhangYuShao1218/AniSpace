# 這是 .env 的範例設定檔 (請勿將包含真實金鑰的 .env 上傳至 Git)
# 請將此檔案複製並重新命名為 .env，然後填寫您的真實資料

# Google Gemini API 金鑰
# 用途：動畫標題自動翻譯、蝦皮商品圖片過濾精選
GEMINI_API_KEY=your_gemini_api_key_here

# 自動化報表 Email 設定 (Gmail)
# 用途：每日爬蟲與檢查流程完畢後，發送結果報告
EMAIL_USER=your_email@gmail.com
# 請注意：若是使用 Gmail，此處請填入 16 碼的「Google 應用程式密碼」，而非您的登入密碼
EMAIL_PASS=your_gmail_app_password_here
